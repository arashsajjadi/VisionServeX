# VisionServeX environment configuration template.
# Copy this file to `.env` and edit values. Never commit `.env`.

# ---- Server ----
VISIONSERVEX_SERVER__HOST=127.0.0.1
VISIONSERVEX_SERVER__PORT=8080
VISIONSERVEX_SERVER__PUBLIC_MODE=false

# ---- Authentication ----
# When true, all non-health endpoints require an API key.
VISIONSERVEX_AUTH__ENABLED=false
# Generate a strong key: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
VISIONSERVEX_AUTH__API_KEY=

# ---- Limits ----
VISIONSERVEX_LIMITS__MAX_UPLOAD_BYTES=20971520
VISIONSERVEX_LIMITS__MAX_IMAGE_PIXELS=33177600
VISIONSERVEX_LIMITS__RATE_LIMIT_PER_MINUTE=120

# ---- CORS (disabled by default; comma separated allowlist) ----
VISIONSERVEX_CORS__ALLOWED_ORIGINS=

# ---- Cache / models ----
# Defaults to a per-user cache directory; override here if desired.
# VISIONSERVEX_CACHE__CACHE_DIR=/var/cache/visionservex

# ---- Runtime ----
VISIONSERVEX_RUNTIME__DEVICE_PREFERENCE=auto
VISIONSERVEX_RUNTIME__PRECISION_PREFERENCE=auto
VISIONSERVEX_RUNTIME__MAX_LOADED_MODELS=2
VISIONSERVEX_RUNTIME__QUEUE_SIZE=64
VISIONSERVEX_RUNTIME__REQUEST_TIMEOUT_S=60

# ---- Remote image URL ingestion (off by default to prevent SSRF) ----
VISIONSERVEX_INPUTS__ALLOW_URL_INPUTS=false
VISIONSERVEX_INPUTS__ALLOW_LOCAL_PATHS=false

# ---- Cloudflare Tunnel ----
VISIONSERVEX_TUNNEL__PROVIDER=cloudflare
VISIONSERVEX_TUNNEL__TUNNEL_NAME=visionservex
# Optional Cloudflare Access service token (DO NOT commit real values).
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
